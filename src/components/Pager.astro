---
// Newspaper-style pager for the Daily Notes index. Notes are sorted newest-first, so the previous
// page holds NEWER notes and the next page holds OLDER ones. Page 1 lives at /field-notes/;
// pages 2+ at /field-notes/page/<n>/.
interface Props { current: number; total: number }
const { current, total } = Astro.props;
const href = (p: number) => (p <= 1 ? '/field-notes/' : `/field-notes/page/${p}/`);
const prev = current > 1 ? current - 1 : null;
const next = current < total ? current + 1 : null;
---

{total > 1 && (
  <nav class="pager" aria-label="Daily Notes pagination">
    {prev ? <a class="pager-link" href={href(prev)} rel="prev">← Newer</a>
          : <span class="pager-link is-off">← Newer</span>}
    <span class="pager-now">Page {current} / {total}</span>
    {next ? <a class="pager-link" href={href(next)} rel="next">Older →</a>
          : <span class="pager-link is-off">Older →</span>}
  </nav>
)}

<style>
  .pager {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    margin-top: 34px; padding-top: 20px; border-top: 1px solid var(--ink);
    font-family: var(--mono); font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase;
  }
  .pager-link { text-decoration: none; color: var(--build); }
  .pager-link:hover { text-decoration: underline; }
  .pager-link.is-off { color: var(--faint); pointer-events: none; }
  .pager-now { color: var(--muted); }
</style>
