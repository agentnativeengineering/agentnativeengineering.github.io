---
// Shareable-card action row: LINK · COPY · IMAGE · X · LinkedIn.
// Drop this inside any element marked `data-shareable` that also carries
// data-share-url / data-share-title / data-share-text (and optional data-share-slug).
// All behaviour is wired once, site-wide, by the delegated handler in Base.astro.
// The row is excluded from the PNG export via data-share-skip.
---

<div class="share-row" data-share-skip role="group" aria-label="Share this card">
  <button type="button" class="share-btn" data-share="link" aria-label="Copy link">
    <span class="share-label">LINK</span>
  </button>
  <button type="button" class="share-btn" data-share="copy" aria-label="Copy text">
    <span class="share-label">COPY</span>
  </button>
  <button type="button" class="share-btn" data-share="image" aria-label="Download as image">
    <span class="share-label">IMAGE</span>
  </button>
  <button type="button" class="share-btn icon" data-share="x" aria-label="Share on X">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"></path></svg>
  </button>
  <button type="button" class="share-btn icon" data-share="linkedin" aria-label="Share on LinkedIn">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0Z"></path></svg>
  </button>
</div>
