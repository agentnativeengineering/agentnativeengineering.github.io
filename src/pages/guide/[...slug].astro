---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import ForAgents from '../../components/ForAgents.astro';
import CopyGuideButton from '../../components/CopyGuideButton.astro';
import { GUIDE_VERSION, GUIDE_REVISED } from '../../data/site';
import { accentOf, phaseLabel, type Phase } from '../../data/phase';

export async function getStaticPaths() {
  const domains = (await getCollection('guide', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order,
  );
  return domains.map((domain, i) => ({
    params: { slug: domain.id },
    props: { domain, prev: domains[i - 1] ?? null, next: domains[i + 1] ?? null },
  }));
}

const { domain, prev, next } = Astro.props;
const { Content } = await render(domain);
const { title, order, phase, question, principles, tools, updated } = domain.data;
const accent = accentOf(phase as Phase);
const num = String(order).padStart(2, '0');
const revised = (updated ?? new Date(GUIDE_REVISED)).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  active="guide"
  title={`${title} — Agent Native Engineering`}
  description={domain.data.summary ?? question}
>
  <div class="wrap" data-r="pad">
    <article class="article" style={`--accent:${accent}`}>
      <a class="backlink" href="/guide/">← Field Guide</a>

      <header style="margin:22px 0 0">
        <div class="eyebrow" style="color:var(--accent)">// FIELD GUIDE · DOMAIN {num}</div>
        <h1 class="page-h1" data-r="page-h1" style="font-size:46px;margin:14px 0 0">{title}</h1>
        <p class="page-dek" style="margin-top:16px;max-width:62ch">{question}</p>
        <div class="article-meta" style="margin-top:20px;padding:14px 0;border-top:1px solid var(--hair);border-bottom:1px solid var(--hair)">
          <span class="badge">{phaseLabel(phase as Phase)}</span>
          <span><span class="k">Guide</span> v{GUIDE_VERSION}</span>
          <span><span class="k">Revised</span> {revised}</span>
        </div>
      </header>

      {principles.length > 0 && (
        <section class="principles">
          {principles.map((p, i) => (
            <div class="principle">
              <span class="pn">P{i + 1}</span>
              <p>{p}</p>
            </div>
          ))}
        </section>
      )}

      <div class="prose"><Content /></div>

      {tools.length > 0 && (
        <section class="blocks">
          <div class="eyebrow" style="color:var(--faint);letter-spacing:0.14em">BUILDING BLOCKS</div>
          <div class="chip-row">{tools.map((t) => <span class="chip-alt">{t}</span>)}</div>
        </section>
      )}

      <nav class="prevnext">
        <span>{prev && <a href={`/guide/${prev.id}/`}>← {prev.data.title}</a>}</span>
        <span>{next && <a href={`/guide/${next.id}/`}>{next.data.title} →</a>}</span>
      </nav>
    </article>

    <ForAgents description="— this domain, structured and sourced. Feed the guide to your own agent.">
      <CopyGuideButton />
      <a class="fa-btn ghost" href="/agent.json">agent.json</a>
      <a class="fa-btn faint" href="/rss.xml">RSS</a>
    </ForAgents>
  </div>

  <Footer slot="footer" variant="slim" left={`Domain ${num} · <span class="strong">${title}</span> · CC BY 4.0`} />
</Base>

<style>
  .principles { margin: 34px 0; display: flex; flex-direction: column; gap: 0; }
  .principle { display: grid; grid-template-columns: auto 1fr; gap: 16px; align-items: start; padding: 16px 0; border-top: 1px dashed var(--hair-dash); }
  .principle:first-child { border-top: none; }
  .principle .pn { font-family: var(--mono); font-weight: 600; font-size: 12px; color: var(--accent); border: 1.5px solid var(--accent); border-radius: 3px; padding: 4px 9px; }
  .principle p { font-family: var(--serif); font-weight: 500; font-size: 19px; line-height: 1.4; letter-spacing: -0.01em; color: var(--ink); margin: 0; text-wrap: pretty; }
  .blocks { margin-top: 36px; padding-top: 18px; border-top: 1px solid var(--hair); }
  .chip-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .prevnext { margin-top: 38px; padding-top: 18px; border-top: 1px solid var(--hair); display: flex; justify-content: space-between; gap: 16px; font-family: var(--mono); font-size: 12.5px; }
  .prevnext a { color: var(--ink); text-decoration: none; }
  .prevnext a:hover { color: var(--accent); }
</style>
