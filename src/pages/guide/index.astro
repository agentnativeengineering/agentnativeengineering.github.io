---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import ForAgents from '../../components/ForAgents.astro';
import CopyGuideButton from '../../components/CopyGuideButton.astro';
import DomainCard from '../../components/DomainCard.astro';

const domains = (await getCollection('guide', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
const principleCount = domains.reduce((n, d) => n + d.data.principles.length, 0);
---

<Base
  active="guide"
  title="The Guide — Agent Native Engineering"
  description="Twelve engineering domains for building agents that hold up in production — each with the principles it comes down to, grounded in real-world examples and studies."
>
  <div class="wrap" data-r="pad">
    <header class="page-header">
      <div class="eyebrow">// THE GUIDE</div>
      <h1 class="page-h1" data-r="page-h1" style="margin-top:16px">The Guide</h1>
      <p class="page-dek">Twelve core areas of building agents that actually work — explained from the ground up, with the principles each one comes down to and real examples from teams shipping today.</p>
      <p class="guide-count">{domains.length} domains · {principleCount} principles</p>
    </header>

    <section class="section" style="padding-top:32px">
      <div class="domains-grid">
        {domains.map((d) => <DomainCard domain={d} />)}
      </div>
    </section>

    <ForAgents description="— every domain ships structured, grounded in real-world examples and studies. Feed the guide to your own agent.">
      <CopyGuideButton />
      <a class="fa-btn ghost" href="/#machine">llms.txt</a>
      <a class="fa-btn ghost" href="/#machine">agent.json</a>
      <a class="fa-btn faint" href="/rss.xml">RSS</a>
    </ForAgents>
  </div>

  <Footer slot="footer" variant="slim" left={'The Guide · <span class="strong">Agent Native Engineering</span> · CC BY 4.0'} />
</Base>

<style>
  .guide-count { font-family: var(--mono); font-size: 11.5px; color: var(--faint); margin: 14px 0 0; }
  .domains-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 28px 22px; }
  @media (max-width: 760px) { .domains-grid { grid-template-columns: 1fr; } }
</style>
