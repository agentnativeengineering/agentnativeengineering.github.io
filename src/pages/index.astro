---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import ForAgents from '../components/ForAgents.astro';
import Player from '../components/Player.astro';
import DomainCard from '../components/DomainCard.astro';
import CopyGuideButton from '../components/CopyGuideButton.astro';

const domains = (await getCollection('guide', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const notesAll = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const notes = notesAll.slice(0, 5);

const episodes = (await getCollection('episodes', ({ data }) => !data.draft)).sort(
  // newest date first; on a same-date tie the later edition (by id) wins, so the freshest
  // brief is featured even when two editions share a day.
  (a, b) => (b.data.date.valueOf() - a.data.date.valueOf()) || b.id.localeCompare(a.id),
);
const featured = episodes[0] ?? null;

const today = new Date();
const dateLong = today.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }).toUpperCase();
const fmtShort = (d: Date) => d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();
const fmtNote = (d: Date) => d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' }).toUpperCase();
const readMin = (body: string) => Math.max(1, Math.round((body.trim().split(/\s+/).length) / 200));

const ticker = notesAll.slice(0, 4).map((n) => n.data.title);
---

<Base>
  <div class="wrap" data-r="pad">
    <!-- Masthead -->
    <header class="masthead">
      <div class="dateline">
        <span class="live"><span class="dot"></span>LIVE — TODAY'S EDITION</span>
        <span class="sep">·</span>
        <span class="strong">{dateLong}</span>
        <span class="sep">·</span>
        <span>EDITION No. {notesAll.length}</span>
      </div>
      <div class="nameplate-wrap">
        <div class="nameplate-kicker">// OPEN KNOWLEDGE · BUILD · OPERATE · ENGINEER</div>
        <h1 class="nameplate" data-r="hero-h1">Agent Native Engineering</h1>
        <p class="nameplate-sub"><span style="color:var(--build);font-weight:500">Open knowledge</span>: a field guide, daily brief, and reference architecture for building AI agents in production — grounded in real-world examples and studies, not opinion.</p>
      </div>
      <div class="masthead-rule"></div>
      <div class="ticker">
        <div class="ticker-track">
          {[...ticker, ...ticker].map((t) => (
            <span class="ticker-item"><span class="slash">/</span>{t}</span>
          ))}
        </div>
      </div>
    </header>

    <!-- Hero: the loop + featured Daily Brief -->
    <section class="hero-grid">
      <div class="card" style="padding:30px 32px;display:flex;flex-direction:column">
        <div style="margin-bottom:18px"><span class="badge">THE LOOP</span></div>
        <p class="loop-copy">
          <strong>Agent-Native Engineering</strong> is an open community for building, operating, and engineering with AI agents in production, built on existing open protocols and open-source projects. The work is a loop: <span class="hi">build</span> agents, <span class="hi">operate</span> them reliably, and let them take on the <span class="hi">engineering</span> that builds and runs the next ones.
        </p>
        <div class="loop-pills">
          <span>BUILD</span><span class="arrow">→</span><span>OPERATE</span><span class="arrow">→</span><span>ENGINEER</span>
        </div>
      </div>

      {featured && (
        <div class="card card-dark" style="padding:30px 32px;display:flex;flex-direction:column">
          <div class="brief-label">DAILY BRIEF · {fmtShort(featured.data.date)}</div>
          <h2 class="brief-title">{featured.data.title}</h2>
          {featured.data.summary && <p class="brief-dek">{featured.data.summary}</p>}
          <div style="margin-top:auto;padding-top:26px">
            <Player src={featured.data.audio} seconds={featured.data.seconds} />
          </div>
          <div class="brief-links">
            <a class="brief-btn solid" href={`/daily-brief/${featured.id}/`}>Open full edition</a>
            <a class="brief-btn ghost" href="/daily-brief/">YouTube</a>
            <a class="brief-btn ghost" href="/daily-brief/">Spotify</a>
          </div>
        </div>
      )}
    </section>

    <!-- Recent Notes -->
    <section class="section" id="notes">
      <div class="section-head">
        <span class="section-no">// 01</span>
        <h2 class="section-title">Recent Notes</h2>
        <a class="section-link" href="/field-notes/" style="margin-left:auto">All notes →</a>
      </div>
      <p class="section-intro">Dated notes from the work — what was tried, what broke, what was learned. Drawn from real-world examples and studies, not opinion.</p>
      <div class="entries">
        {notes.map((n) => (
          <a class="entry-row" href={`/field-notes/${n.id}/`}>
            <span class="date">{fmtNote(n.data.date)}</span>
            <span class="ttl">{n.data.title}</span>
            <span class="meta">
              {n.data.tags[0] && <span class="domain" style="--accent:#b8430f">{n.data.tags[0]}</span>}
              <span class="pill">{readMin(n.body ?? '')} min</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- The Guide -->
    <section class="section" id="guide">
      <div class="section-head">
        <span class="section-no">// 02</span>
        <h2 class="section-title">Field Guide</h2>
        <span class="section-meta" style="margin-left:auto">{domains.length} domains</span>
      </div>
      <p class="section-intro">Twelve core areas of building agents that actually work — explained from the ground up, with the principles each one comes down to and real examples from teams shipping today.</p>
      <div class="domains-grid">
        {domains.map((d) => <DomainCard domain={d} />)}
      </div>
    </section>

    <ForAgents description="— every domain ships structured, grounded in real-world examples and studies. Feed the guide to your own agent.">
      <CopyGuideButton />
      <a class="fa-btn ghost" href="/llms.txt">llms.txt</a>
      <a class="fa-btn ghost" href="/agent.json">agent.json</a>
      <a class="fa-btn faint" href="/rss.xml">RSS</a>
    </ForAgents>
  </div>

  <Footer slot="footer" variant="full" />
</Base>

<style>
  .hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 24px; padding: 30px 0 8px; }
  .loop-copy { font-family: var(--serif); font-size: 20px; line-height: 1.5; color: var(--ink-2); margin: 0; text-wrap: pretty; }
  .loop-copy .hi { color: var(--build); font-weight: 500; }
  .loop-pills { display: flex; align-items: center; gap: 10px; margin-top: 26px; font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.04em; color: var(--muted); }
  .loop-pills span:not(.arrow) { border: 1px solid #d8d2c5; border-radius: 99px; padding: 5px 13px; }
  .loop-pills .arrow { color: var(--build); border: none; padding: 0; }

  .brief-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; color: var(--signal); }
  .brief-title { font-family: var(--serif); font-weight: 500; font-size: 30px; line-height: 1.18; letter-spacing: -0.01em; margin: 16px 0 0; max-width: 18ch; text-wrap: balance; }
  .brief-dek { font-family: var(--sans); font-size: 14.5px; line-height: 1.6; color: #b8b2a6; margin: 14px 0 0; text-wrap: pretty; }
  .brief-links { display: flex; align-items: center; gap: 9px; flex-wrap: wrap; padding-top: 20px; }
  .brief-btn { font-family: var(--mono); font-size: 12px; text-decoration: none; padding: 8px 15px; border-radius: 3px; }
  .brief-btn.solid { color: var(--dark); background: #e8e2d6; }
  .brief-btn.ghost { color: #e8e2d6; background: transparent; border: 1px solid #45403a; }

  .domains-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 28px 22px; }

  @media (max-width: 760px) {
    .hero-grid { grid-template-columns: 1fr; }
    .domains-grid { grid-template-columns: 1fr; }
  }
</style>
