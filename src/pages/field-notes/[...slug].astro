---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note, i) => ({ params: { slug: note.id }, props: { note, i } }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const fmt = (d: Date) => d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
const words = note.body ? note.body.trim().split(/\s+/).length : 0;
const readMin = Math.max(1, Math.round(words / 200));

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const iso = note.data.date.toISOString().slice(0, 10);
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: note.data.title,
    description: note.data.summary,
    datePublished: iso,
    dateModified: iso,
    url: canonical,
    mainEntityOfPage: canonical,
    keywords: note.data.tags,
    author: { '@type': 'Organization', name: 'Agent Native Engineering' },
    publisher: {
      '@type': 'Organization',
      name: 'Agent Native Engineering',
      logo: { '@type': 'ImageObject', url: new URL('/logo.png', Astro.site).href },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Notes', item: new URL('/field-notes/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: note.data.title, item: canonical },
    ],
  },
];
---

<Base
  title={`${note.data.title} — Agent Native Engineering`}
  description={note.data.summary}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="wrap note">
    <a class="backlink" href="/field-notes/">← Notes</a>
    <div class="art-head">
      <p class="doc-id">Note</p>
      <h1>{note.data.title}</h1>
      <div class="art-meta">
        <span><span class="k">Published</span> {fmt(note.data.date)}</span>
        <span><span class="k">Reading</span> {readMin} min</span>
        {note.data.tags.length > 0 && <span><span class="k">Tags</span> {note.data.tags.join(', ')}</span>}
      </div>
    </div>
    {note.data.takeaways && note.data.takeaways.length > 0 && (
      <aside class="takeaways">
        <h2>Key Takeaways</h2>
        <ul>
          {note.data.takeaways.slice(0, 3).map((t0) => {
            const t = t0.replace(/\*\*/g, '');   // strip stray markdown bold — we bold the lead sentence ourselves
            const i = t.search(/[.!?]\s/);
            const lead = i === -1 ? t : t.slice(0, i + 1);
            const rest = i === -1 ? '' : t.slice(i + 2);
            return <li><b>{lead}</b>{rest ? ' ' + rest : ''}</li>;
          })}
        </ul>
      </aside>
    )}
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
