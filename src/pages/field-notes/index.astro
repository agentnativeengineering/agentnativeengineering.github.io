---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) => d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' });

const byYear = new Map<number, typeof notes>();
for (const n of notes) {
  const y = n.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(n);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base title="Notes — Agent Native Engineering" description="Dated notes from building and operating AI agents in production — what was tried, what broke, what was learned.">
  <section class="wrap masthead" style="padding-bottom:1rem">
    <p class="doc-id">Notes</p>
    <h1 style="font-size:clamp(1.9rem,5vw,2.8rem)">Notes</h1>
    <p class="subtitle">What was tried, what broke, what was learned — dated and attributable.</p>
    <div class="rule"></div>
  </section>

  <section class="wrap section" style="padding-top:2rem">
    {notes.length === 0 && <p style="color:var(--faint);font-family:var(--mono)">No notes yet.</p>}
    {years.map((year) => (
      <div style="margin-bottom:2.2rem">
        <div class="section-head" style="border-top:none;padding-top:0">
          <span class="sec-no" style="font-size:0.95rem">{year}</span>
        </div>
        <div class="entries">
          {byYear.get(year)!.map((note) => (
            <a class="entry-row" href={`/field-notes/${note.id}/`}>
              <span class="date">{fmt(note.data.date)}</span>
              <span class="ttl">{note.data.title}</span>
              {note.data.summary && <span class="ex">{note.data.summary}</span>}
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Base>
