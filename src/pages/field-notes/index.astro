---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = (d: Date) => d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' }).toUpperCase();
const readMin = (body: string) => Math.max(1, Math.round((body.trim().split(/\s+/).length) / 200));

const byYear = new Map<number, typeof notes>();
for (const n of notes) {
  const y = n.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(n);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base
  active="notes"
  title="Daily Notes — Agent Native Engineering"
  description="Dated notes from building and operating AI agents in production — what was tried, what broke, what was learned. Grounded in real-world examples and studies."
>
  <div class="wrap" data-r="pad">
    <header class="page-header">
      <div class="eyebrow">// DAILY NOTES</div>
      <h1 class="page-h1" data-r="page-h1" style="margin-top:16px">Daily Notes</h1>
      <p class="page-dek">What was tried, what broke, what was learned — dated and attributable. Drawn from real-world examples and studies, not opinion.</p>
    </header>

    <section class="section" style="padding-top:30px">
      {notes.length === 0 && <p style="font-family:var(--mono);color:var(--faint)">No notes yet.</p>}
      {years.map((year) => (
        <div style="margin-bottom:14px">
          <div class="section-head"><span class="section-no">{year}</span></div>
          <div class="entries">
            {byYear.get(year)!.map((n) => (
              <a class="entry-row" href={`/field-notes/${n.id}/`}>
                <span class="date">{fmt(n.data.date)}</span>
                <span class="ttl">{n.data.title}</span>
                <span class="meta">
                  {n.data.tags[0] && <span class="domain" style="--accent:#b8430f">{n.data.tags[0]}</span>}
                  <span class="pill">{readMin(n.body ?? '')} min</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  </div>

  <Footer slot="footer" variant="slim" left={'Daily Notes · <span class="strong">Agent Native Engineering</span> · CC BY 4.0'} />
</Base>
