---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Footer from '../../../components/Footer.astro';
import NoteEntries from '../../../components/NoteEntries.astro';
import Pager from '../../../components/Pager.astro';

export async function getStaticPaths() {
  const PAGE_SIZE = 24; // keep in sync with field-notes/index.astro
  const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  const totalPages = Math.max(1, Math.ceil(notes.length / PAGE_SIZE));
  // page 1 is served by index.astro; generate 2..N here
  const paths = [];
  for (let p = 2; p <= totalPages; p++) {
    paths.push({
      params: { n: String(p) },
      props: { pageNotes: notes.slice((p - 1) * PAGE_SIZE, p * PAGE_SIZE), current: p, totalPages },
    });
  }
  return paths;
}

interface Props { pageNotes: CollectionEntry<'notes'>[]; current: number; totalPages: number }
const { pageNotes, current, totalPages } = Astro.props;
---

<Base
  active="notes"
  title={`Daily Notes — page ${current} — Agent Native Engineering`}
  description="Dated notes from building and operating AI agents in production — what was tried, what broke, what was learned. Grounded in real-world examples and studies."
>
  <div class="wrap" data-r="pad">
    <header class="page-header">
      <div class="eyebrow">// DAILY NOTES · PAGE {current} / {totalPages}</div>
      <h1 class="page-h1" data-r="page-h1" style="margin-top:16px">Daily Notes</h1>
      <p class="page-dek">What was tried, what broke, what was learned — dated and attributable. Drawn from real-world examples and studies, not opinion.</p>
    </header>

    <section class="section" style="padding-top:30px">
      <NoteEntries notes={pageNotes} />
      <Pager current={current} total={totalPages} />
    </section>
  </div>

  <Footer slot="footer" variant="slim" left={'Daily Notes · <span class="strong">Agent Native Engineering</span> · CC BY 4.0'} />
</Base>
