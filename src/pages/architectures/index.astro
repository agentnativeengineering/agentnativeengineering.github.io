---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import ForAgents from '../../components/ForAgents.astro';
import { softwareLayer, domainLayer } from '../../data/architecture';
import { accentOf } from '../../data/phase';
---

<Base
  active="architecture"
  title="Reference Architecture — Agent Native Engineering"
  description="A two-layer reference architecture for agents in production: the solutions you implement, nested on top of an all-open-source software stack — one card per Field Guide domain, each filled with the tools that implement it."
>
  <div class="wrap" data-r="pad">
    <header class="page-header">
      <div class="eyebrow">// REFERENCE ARCHITECTURE</div>
      <h1 class="page-h1" data-r="page-h1" style="margin-top:16px">Reference Architecture</h1>
      <p class="page-dek">Two layers. The domain solutions you build sit on top of an open-source software stack, shown as one card per Field Guide domain with the tools that implement it.</p>
    </header>

    <div class="coming-soon" style="margin-top:28px">
      <span class="pill">COMING SOON</span>
      <span class="text"><strong style="font-weight:600">Deployable units.</strong> Each layer is being packaged as a one-command deployable unit — Helm charts and containers you drop straight into your own cluster. <a href="https://github.com/agentnativeengineering" target="_blank" rel="noopener">Follow on GitHub →</a></span>
    </div>

    <section class="section" style="padding-top:36px">
      <!-- Domain layer -->
      <div class="layer-panel engineer" style="--accent:#2f7d56">
        <div class="layer-head">
          <span class="layer-label" style="color:#2f7d56"><span class="sq"></span>DOMAIN LAYER · WHAT YOU IMPLEMENT</span>
        </div>
        <div class="sol-grid">
          {domainLayer.map((d) => (
            <div class="sol-card">
              <span class="sol-tag">{d.tag}</span>
              <span class="sol-name">{d.name}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="layer-connect">
        <span class="k">NESTED ON TOP OF</span>
        <span class="arrow">↓</span>
      </div>

      <!-- Software layer -->
      <div class="layer-panel build" style="--accent:#b8430f">
        <div class="layer-head">
          <span class="layer-label" style="color:#b8430f"><span class="sq"></span>SOFTWARE LAYER · OPEN-SOURCE STACK</span>
          <span class="layer-note">12 domains · ★ = default · self-hostable</span>
        </div>
        <div class="stack-grid">
          {softwareLayer.map((l) => (
            <div class="stack-card" style={`--accent:${accentOf(l.phase)}`}>
              <div class="stack-card-head">
                <a class="stack-name" href={`/guide/${l.slug}/`}><span class="dot"></span>{l.name}</a>
                <span class="stack-num">{l.num}</span>
              </div>
              <div class="chips">
                <span class="chip"><span class="star">★</span>{l.default}</span>
                {l.alts.map((a) => <span class="chip-alt">{a}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>

      <p class="stack-foot">Open-source &amp; self-hostable only · a starting point to fork, not a product to buy · suggest a swap on <a href="https://github.com/agentnativeengineering" target="_blank" rel="noopener">GitHub</a>.</p>
    </section>

    <ForAgents description="— the stack as structured data: layer, default, alternatives, domain. Generate a build manifest for your constraints.">
      <a class="fa-btn solid" href="/agent.json">Download stack .json</a>
      <a class="fa-btn ghost" href="https://github.com/agentnativeengineering" target="_blank" rel="noopener">GitHub →</a>
    </ForAgents>
  </div>

  <Footer slot="footer" variant="slim" left={'Software Layer · <span class="strong">Agent Native Engineering</span> · CC BY 4.0'} />
</Base>

<style>
  .sol-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(176px, 1fr)); gap: 12px; }
  .sol-card { background: var(--card); border: 1.5px solid var(--ink); border-radius: 5px; padding: 13px 14px; display: flex; flex-direction: column; gap: 7px; }
  .sol-tag { font-family: var(--mono); font-size: 9px; letter-spacing: 0.08em; color: var(--engineer); }
  .sol-name { font-family: var(--serif); font-weight: 600; font-size: 16px; line-height: 1.12; color: var(--ink); }

  .stack-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(252px, 1fr)); gap: 14px; }
  .stack-card { background: var(--card); border: 1.5px solid var(--ink); border-radius: 5px; padding: 14px 15px; display: flex; flex-direction: column; gap: 11px; }
  .stack-card-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .stack-name { display: inline-flex; align-items: center; gap: 8px; font-family: var(--serif); font-weight: 600; font-size: 16px; line-height: 1.1; color: var(--ink); text-decoration: none; }
  .stack-name:hover { color: var(--accent); }
  .stack-name .dot { flex: none; width: 8px; height: 8px; border-radius: 2px; background: var(--accent); }
  .stack-num { font-family: var(--mono); font-size: 10px; color: var(--faint-2); }
  .chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .stack-foot { margin-top: 18px; font-family: var(--mono); font-size: 11px; color: var(--faint); }
  .stack-foot a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--faint-2); }
</style>
