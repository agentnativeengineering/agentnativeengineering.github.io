---
import Base from './Base.astro';
import Footer from '../components/Footer.astro';

interface Props {
  label: string;
  title: string;
  blurb: string;
}
const { label, title, blurb } = Astro.props;
---

<Base title={`${title} — Agent Native Engineering`} description={blurb}>
  <div class="wrap" data-r="pad">
    <header class="page-header">
      <div class="eyebrow">// {label.toUpperCase()}</div>
      <h1 class="page-h1" data-r="page-h1" style="margin-top:16px">{title}</h1>
      <p class="page-dek">{blurb}</p>
    </header>

    <div class="coming-soon" style="margin-top:30px">
      <span class="pill">COMING SOON</span>
      <span class="text">This section is in progress. Help shape it on <a href="https://github.com/agentnativeengineering" target="_blank" rel="noopener">GitHub →</a>, or read the <a href="/guide/">Field Guide</a>.</span>
    </div>
  </div>

  <Footer slot="footer" variant="slim" left={`${label} · <span class="strong">Agent Native Engineering</span> · CC BY 4.0`} />
</Base>
