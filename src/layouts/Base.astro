---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  image?: string;
  jsonLd?: Record<string, unknown>[];
  active?: 'daily-brief' | 'notes' | 'guide' | 'architecture' | null;
}

const {
  title = 'Agent Native Engineering — building & operating AI agents in production',
  description = 'A clear guide and daily brief on building AI agents in production — grounded in real-world examples and studies, not opinion.',
  ogType = 'website',
  image = '/logo.png',
  jsonLd = [],
  active = null,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site).href;

const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Agent Native Engineering',
  url: new URL('/', Astro.site).href,
  description:
    'A clear guide and daily brief on building, operating, and engineering with AI agents in production — grounded in real-world examples and studies.',
  publisher: {
    '@type': 'Organization',
    name: 'Agent Native Engineering',
    url: new URL('/', Astro.site).href,
    logo: { '@type': 'ImageObject', url: new URL('/logo.png', Astro.site).href },
  },
};
const schemas = [siteSchema, ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="alternate" type="application/rss+xml" title="Agent Native Engineering" href="/rss.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Agent Native Engineering" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {schemas.map((s) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <Nav active={active} />
    <main><slot /></main>
    <slot name="footer"><Footer /></slot>

    <script>
      // Delegated share handler for every `[data-shareable]` card on the page.
      // Actions read the card's data-share-url / -title / -text / -slug.
      const flash = (btn: HTMLElement, msg: string) => {
        const label = btn.querySelector<HTMLElement>('.share-label');
        if (!label) return;
        const old = label.textContent;
        label.textContent = msg;
        btn.classList.add('done');
        window.setTimeout(() => {
          label.textContent = old;
          btn.classList.remove('done');
        }, 1400);
      };

      document.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement)?.closest<HTMLElement>('[data-share]');
        if (!btn) return;
        const card = btn.closest<HTMLElement>('[data-shareable]');
        if (!card) return;
        e.preventDefault();

        const url = card.dataset.shareUrl || location.href;
        const title = card.dataset.shareTitle || document.title;
        const text = card.dataset.shareText || title;
        const slug = card.dataset.shareSlug || 'ane-card';

        try {
          switch (btn.dataset.share) {
            case 'link':
              await navigator.clipboard.writeText(url);
              flash(btn, 'COPIED');
              break;
            case 'copy':
              await navigator.clipboard.writeText(`${text}\n\n${url}`);
              flash(btn, 'COPIED');
              break;
            case 'x':
              window.open(
                `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`,
                '_blank',
                'noopener,noreferrer',
              );
              break;
            case 'linkedin':
              window.open(
                `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`,
                '_blank',
                'noopener,noreferrer',
              );
              break;
            case 'image': {
              flash(btn, '…');
              const { toPng } = await import('html-to-image');
              const paper =
                getComputedStyle(document.documentElement).getPropertyValue('--paper').trim() ||
                '#f6f4ee';
              const dataUrl = await toPng(card, {
                pixelRatio: 2,
                backgroundColor: paper,
                filter: (n) => !(n instanceof HTMLElement && n.dataset.shareSkip !== undefined),
              });
              const a = document.createElement('a');
              a.download = `${slug}.png`;
              a.href = dataUrl;
              a.click();
              flash(btn, 'SAVED');
              break;
            }
          }
        } catch (err) {
          console.error('share action failed', err);
          flash(btn, 'ERROR');
        }
      });
    </script>
  </body>
</html>
