---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Agent Native Engineering — operating agents in production',
  description = 'Open engineering knowledge for building and operating AI agents in production: durability, reliability, security, access control, observability, and evals — every claim sourced.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="alternate" type="application/rss+xml" title="Agent Native Engineering" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <header class="site-head">
      <div class="wrap">
        <a class="brand" href="/">
          agentnative<span class="dim">engineering</span><span class="bracket">/</span>
        </a>
        <nav class="nav">
          <a href="/guide/">Field&nbsp;Guide</a>
          <a href="/architectures/" class="hide">Architectures</a>
          <a href="/field-notes/">Notes</a>
          <a href="https://github.com/agentnativeengineering">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <div class="foot-links">
          <a href="/guide/">Field Guide</a>
          <a href="/architectures/">Architectures</a>
          <a href="/field-notes/">Notes</a>
          <a href="/contribute/">Contribute</a>
          <a href="/glossary/">Glossary</a>
          <a href="/cite/">Cite</a>
          <a href="/rss.xml">RSS</a>
          <a href="https://github.com/agentnativeengineering">GitHub</a>
        </div>
        <p class="colophon">
          Agent-Native Engineering — open knowledge under <a href="https://creativecommons.org/licenses/by/4.0/">CC&nbsp;BY&nbsp;4.0</a> · © {year}
        </p>
      </div>
    </footer>
  </body>
</html>
